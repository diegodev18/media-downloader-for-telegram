# Token del bot de Telegram (obtenerlo con @BotFather)
BOT_TOKEN=<your_bot_token_here>

# Cookies de YouTube en formato Netscape (para descargar vídeos con restricciones).
# Exportar desde el navegador o usar una extensión de cookies.
COOKIES=<your_cookies_here>

# Opcional. IDs de chat permitidos (usuarios o grupos). Solo esos chats podrán usar el bot.
# Formato: números separados por comas. Si no se define, el bot acepta todos los chats.
# Ejemplo: 123456789,-987654321
# ALLOWED_CHAT_IDS=123456789,-987654321

# Opcional. Límite de descargas por ventana de tiempo (evitar abuso).
# RATE_LIMIT_MAX=10
# RATE_LIMIT_WINDOW_MS=3600000

# Opcional. IDs de chat con permisos de admin (p. ej. para /stats). Si no se define, se usa ALLOWED_CHAT_IDS.
# ADMIN_CHAT_IDS=123456789

# Opcional. ID del canal al que el bot reenvía cada vídeo descargado (debe estar añadido el bot al canal).
# CHANNEL_ID=-1001234567890
